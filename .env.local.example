# URL del servidor FastAPI (Core Swicht V2).
# Para desarrollo típico: http://127.0.0.1:8000
# Las peticiones del cliente irán por proxy de Next.js: /api/backend/*
BACKEND_URL=http://127.0.0.1:8000

# Modo al arrancar (solo se aplica al lanzar `next dev` / `next build`; no hay switch en pantalla).
# main = API Core Swicht. test = simulación (o usa el script `npm run dev:test`).
# NEXT_PUBLIC_BOOT_RUN_MODE=main
